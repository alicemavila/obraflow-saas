# ==============================================================================
# ObraFlow — Variáveis de ambiente
# ==============================================================================
#
# Configuração local recomendada:
#
# 1. Copie este arquivo para criar o .env.local:
#    Copy-Item .env.example .env.local
#
# 2. Crie também um arquivo .env contendo pelo menos DATABASE_URL,
#    pois o Prisma CLI carrega esse arquivo diretamente.
#
# 3. Nunca envie .env, .env.local ou .env.sentry-build-plugin ao GitHub.
# ==============================================================================

# ─── Aplicação ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Diário de Obras"

# ─── Banco de dados ─────────────────────────────────────────────────────────────
#
# Em desenvolvimento local, deve corresponder às credenciais do docker-compose.

DATABASE_URL="postgresql://dev:devpass@localhost:5432/diariobras?schema=public"

# ─── Autenticação — Auth.js / NextAuth ─────────────────────────────────────────
#
# Gerar uma chave:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

AUTH_SECRET="gere-uma-chave-local-segura"
NEXTAUTH_URL=http://localhost:3000

# ─── Monitoramento — Sentry ─────────────────────────────────────────────────────
#
# DSN público do projeto do Sentry.
# Não coloque SENTRY_AUTH_TOKEN neste arquivo.

NEXT_PUBLIC_SENTRY_DSN="https://SEU_DSN_DO_SENTRY"

# O token administrativo para source maps deve ser configurado:
#
# - localmente em .env.sentry-build-plugin;
# - no GitHub Actions como secret;
# - no servidor por meio de um gerenciador de secrets.
#
# SENTRY_AUTH_TOKEN=

# ─── Storage — Cloudflare R2 ────────────────────────────────────────────────────
R2_ACCOUNT_ID="seu-account-id-cloudflare"
R2_ACCESS_KEY_ID="sua-r2-access-key-id"
R2_SECRET_ACCESS_KEY="sua-r2-secret-access-key"
R2_BUCKET_NAME="diario-obras-files"
R2_PUBLIC_URL="https://pub-XXXX.r2.dev"
R2_ENDPOINT="https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com"

# ─── Storage — AWS S3, alternativa opcional ─────────────────────────────────────
# AWS_ACCESS_KEY_ID="sua-aws-access-key"
# AWS_SECRET_ACCESS_KEY="seu-aws-secret-key"
# AWS_REGION="sa-east-1"
# AWS_S3_BUCKET="diario-obras-files"

# ─── E-mail — Resend ─────────────────────────────────────────────────────────────
RESEND_API_KEY="re_sua_chave_aqui"
EMAIL_FROM="noreply@seudominio.com.br"
EMAIL_FROM_NAME="Diário de Obras"

# ─── Uploads ─────────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
MAX_PDF_SIZE_MB=50

# ─── Rate limiting ────────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_API_REQUESTS_PER_MINUTE=100